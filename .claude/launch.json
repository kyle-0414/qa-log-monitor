{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Dev (Frontend + Backend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "."
    },
    {
      "name": "Vite (Frontend only)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:client"],
      "port": 5173,
      "cwd": "."
    },
    {
      "name": "Express API (Backend only)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server/index.js"],
      "port": 3001,
      "cwd": "."
    }
  ]
}
